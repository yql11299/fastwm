# ===========================================
# 证件水印处理系统 - .gitignore
# ===========================================

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# 后端
server/node_modules/

# 前端
client/node_modules/
client/dist/
client/.vite/

# 测试覆盖率
coverage/

# 环境变量（不要提交包含密钥的文件）
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*.swn
.DS_Store
Thumbs.db

# 日志
*.log
logs/

# Docker 数据（保持目录结构但不提交内容）
data/
!data/.gitkeep

# 临时文件
tmp/
temp/
*.tmp
*.bak
*.backup

# 编译产物
*.o
*.obj
*.exe

# OS
.DS_Store
Thumbs.db
desktop.ini

# 后端数据（用户数据不应提交）
server/data/
server/exports/

# 字体（如果字体文件过大，可选择不提交）
fonts/*.ttf
fonts/*.otf
!fonts/.gitkeep

# 测试文件
test_*
*.test.js
*.spec.js
__tests__/

# 证书和敏感文件
*.pem
*.key
*.crt
cookies.txt

# 部署相关（不需要提交到仓库）
docker-compose.override.yml
*.pid