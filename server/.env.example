# 证件水印处理系统 - 环境变量配置
# 复制此文件为 .env 并修改相应值

# ===========================================
# 基础配置
# ===========================================

# 运行环境
NODE_ENV=development

# 服务端口
PORT=3000

# ===========================================
# JWT 认证配置
# ===========================================

# JWT 密钥（生产环境必须修改为强密码，至少 32 字符）
JWT_SECRET=dev-only-secret-do-not-use-in-production

# Token 过期时间
JWT_EXPIRES_IN=7d

# ===========================================
# 目录配置
# 如需自定义目录路径，取消注释并修改
# ===========================================

# 字体文件目录
# FONTS_PATH=/path/to/fonts

# 用户数据目录
# USERS_PATH=/path/to/users

# 证件文档目录
# DOCUMENTS_PATH=/path/to/documents

# 导出的水印文件目录（24 小时自动清理）
# EXPORTS_PATH=/path/to/exports

# 背景图片目录
# BACKGROUNDS_PATH=/path/to/backgrounds

# ===========================================
# 处理限制
# ===========================================

# 最大文件大小（字节），默认 20MB
# MAX_FILE_SIZE=20971520

# 每批最大文件数
# MAX_FILES_PER_BATCH=100
